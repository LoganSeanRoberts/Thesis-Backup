@article{GLENNBOYD1996493,
title = {Model-independent determinations of B → Dlν, D∗lν form factors},
journal = {Nuclear Physics B},
volume = {461},
number = {3},
pages = {493-511},
year = {1996},
issn = {0550-3213},
doi = {https://doi.org/10.1016/0550-3213(95)00653-2},
url = {https://www.sciencedirect.com/science/article/pii/0550321395006532},
author = {C. {Glenn Boyd} and Benjamín Grinstein and Richard F. Lebed},
abstract = {We present non-perturbative, model-independent parametrizations of the individual QCD form factors relevant to B → D∗lν and B → Dlν decays. These results follow from dispersion relations and analyticity, without recourse to heavy quark symmetry. To describe a form factor with two percent accuracy, three parameters are necessary, one of which is its normalization at zero recoil, F(1). We combine the individual form factors using heavy quark symmetry to extract values for the product |Vcb|F(1) from B → D∗lν data with negligible extrapolation uncertainty.}
}

